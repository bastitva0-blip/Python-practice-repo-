import threading
import time
import random

# Shared resource and tracking variables
shared_database = "Initial Data"
read_count = 0

# Locks for synchronization
# 1. Controls access to the tracking counter 'read_count'
mutex = threading.Lock()
# 2. Controls exclusive access to the shared database for writers
db_lock = threading.Lock()

def reader(reader_id):
    global read_count
    
    while True:
        # --- Entry Section ---
        with mutex:
            read_count += 1
            # If this is the very first reader, lock the database out from writers
            if read_count == 1:
                db_lock.acquire()
        
        # --- Critical Section (Reading) ---
        print(f"[Reader {reader_id}] is reading: '{shared_database}' (Active readers: {read_count})")
        time.sleep(random.uniform(0.5, 1.5))  # Simulate reading time
        
        # --- Exit Section ---
        with mutex:
            read_count -= 1
            # If this is the last reader leaving, unlock the database for waiting writers
            if read_count == 0:
                db_lock.release()
                
        # Remainder section (simulate time outside critical section)
        time.sleep(random.uniform(1.0, 3.0))

def writer(writer_id):
    global shared_database
    
    while True:
        # --- Entry Section ---
        # Writers request exclusive access to the database lock directly
        db_lock.acquire()
        
        # --- Critical Section (Writing) ---
        new_data = f"Data updated by Writer {writer_id}"
        shared_database = new_data
        print(f"👉 [Writer {writer_id}] is writing: '{new_data}'")
        time.sleep(random.uniform(1.0, 2.0))  # Simulate writing time
        
        # --- Exit Section ---
        db_lock.release()
        
        # Remainder section (simulate time outside critical section)
        time.sleep(random.uniform(2.0, 4.0))

# --- Main Driver Code ---
if __name__ == "__main__":
    print("Starting Readers-Writers Simulation...")
    
    # Create 3 Reader threads and 2 Writer threads
    readers = [threading.Thread(target=reader, args=(i,), daemon=True) for i in range(1, 4)]
    writers = [threading.Thread(target=writer, args=(i,), daemon=True) for i in range(1, 3)]
    
    # Boot up all threads
    for t in readers + writers:
        t.start()
        
    # Let the simulation run for 10 seconds before quitting
    time.sleep(10)
    print("\nSimulation Finished.")

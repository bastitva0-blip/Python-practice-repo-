import threading
import time
import random

# Number of philosophers and forks
NUM_PHILOSOPHERS = 5

class Philosopher(threading.Thread):
    def __init__(self, index, left_fork, right_fork):
        super().__init__()
        self.index = index
        self.left_fork = left_fork
        self.right_fork = right_fork
        self.running = True

    def run(self):
        while self.running:
            self.think()
            self.eat()

    def think(self):
        print(f"Philosopher {self.index} is thinking.")
        time.sleep(random.uniform(1, 3))  # Simulate thinking time

    def eat(self):
        # Asymmetric Strategy to prevent deadlock:
        # The last philosopher picks up the right fork first, others pick up the left fork first.
        if self.index == NUM_PHILOSOPHERS - 1:
            first_fork, second_fork = self.right_fork, self.left_fork
        else:
            first_fork, second_fork = self.left_fork, self.right_fork

        print(f"Philosopher {self.index} is hungry and reaching for forks.")
        
        # Acquire both forks safely
        with first_fork:
            print(f"Philosopher {self.index} picked up first fork.")
            with second_fork:
                print(f"Philosopher {self.index} picked up second fork and started eating.")
                time.sleep(random.uniform(1, 2))  # Simulate eating time
                print(f"Philosopher {self.index} finished eating and put down forks.")

def main():
    # Initialize 5 locks representing 5 shared forks
    forks = [threading.Lock() for _ in range(NUM_PHILOSOPHERS)]
    
    # Initialize philosophers and assign their adjacent forks
    philosophers = []
    for i in range(NUM_PHILOSOPHERS):
        left_fork = forks[i]
        right_fork = forks[(i + 1) % NUM_PHILOSOPHERS]
        philosophers.append(Philosopher(i, left_fork, right_fork))

    print("--- Starting Dining Philosophers Simulation ---")
    for p in philosophers:
        p.start()

    # Let the simulation run for 10 seconds before terminating cleanly
    time.sleep(10)
    print("\n--- Stopping Simulation ---")
    for p in philosophers:
        p.running = False
        
    for p in philosophers:
        p.join()

if __name__ == "__main__":
    main()
